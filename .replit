modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "lean-proof"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "kernel-numerics"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "morningstar-tamper"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "zeta-burst-101-10000"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "zeta-sieve-14159-100000"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "towers-build"

[[workflows.workflow]]
name = "lean-proof"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "STRICT_LEAN_CHECK=1 ./scripts/check-lean-proof.sh"

[[workflows.workflow]]
name = "kernel-numerics"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m pytest tests/test_kernel.py -q"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "morningstar-tamper"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m pytest tests/test_morningstar.py -q"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "zeta-burst-101-10000"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python lab.py -c \"zeta_burst(101, 10000)\""

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "zeta-sieve-14159-100000"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python lab.py -c \"zeta_sieve(14159, 100000)\""

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "towers-build"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/check-towers.sh"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3000

[[ports]]
localPort = 8083
externalPort = 3001

[[ports]]
localPort = 23179
externalPort = 80

[nix]
channel = "stable-25_05"
packages = ["freetype", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "tcl", "tesseract", "tk", "zlib"]
